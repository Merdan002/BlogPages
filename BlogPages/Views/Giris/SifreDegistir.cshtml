@{
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="topbar">
    <div>
        <h4>🛡️ Şifre Değiştir</h4>
        <small style="color:#6060a0">Hesap güvenliğin için şifreni güncelle.</small>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="form-card">

            @if (ViewBag.Hata != null)
            {
                <div style="background:rgba(220,53,69,0.15); border:1px solid rgba(220,53,69,0.3);
                    color:#f87171; padding:12px 16px; border-radius:10px; margin-bottom:20px;">
                    <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.Hata
                </div>
            }

            @if (ViewBag.Basari != null)
            {
                <div style="background:rgba(25,135,84,0.15); border:1px solid rgba(25,135,84,0.3);
                    color:#4ade80; padding:12px 16px; border-radius:10px; margin-bottom:20px;">
                    <i class="fas fa-check-circle me-2"></i>@ViewBag.Basari
                </div>
            }

            <form method="post">
                <div class="mb-4">
                    <label class="form-label">Mevcut Şifre</label>
                    <input type="password" name="eskiSifre" class="form-control" placeholder="••••••••" />
                </div>
                <div class="mb-4">
                    <label class="form-label">Yeni Şifre</label>
                    <input type="password" name="yeniSifre" class="form-control" placeholder="••••••••" />
                </div>
                <div class="mb-4">
                    <label class="form-label">Yeni Şifre Tekrar</label>
                    <input type="password" name="yeniSifreTekrar" class="form-control" placeholder="••••••••" />
                </div>
                <button type="submit" class="btn-save">
                    <i class="fas fa-save me-2"></i>Şifreyi Güncelle
                </button>
            </form>
        </div>
    </div>
</div>