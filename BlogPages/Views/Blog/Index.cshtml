@model List<KisselBlog.Models.BlogYazisi>

<!-- TOPBAR -->
<div class="topbar">
    <div>
        <h4>📊 Dashboard</h4>
        <small style="color:#6060a0">Hoş geldin! Blog yazılarını buradan yönet.</small>
    </div>
    <a href="/Blog/Ekle" class="btn-new"><i class="fas fa-plus me-2"></i>Yeni Yazı</a>
</div>

<!-- STAT CARDS -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="icon icon-purple"><i class="fas fa-pen-nib"></i></div>
            <h3>@Model.Count</h3>
            <p>Toplam Yazı</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="icon icon-blue"><i class="fas fa-calendar"></i></div>
            <h3>@Model.Count(x => x.Tarih.Month == DateTime.Now.Month)</h3>
            <p>Bu Ay Yazılan</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="icon icon-green"><i class="fas fa-clock"></i></div>
            <h3>@(Model.Any() ? Model.Max(x => x.Tarih).ToString("dd MMM") : "-")</h3>
            <p>Son Yazı Tarihi</p>
        </div>
    </div>
</div>

<!-- YAZI LİSTESİ -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 style="color:white">📝 Yazılar</h5>
    <small style="color:#6060a0">@Model.Count yazı bulundu</small>
</div>

<form method="get" action="/Blog" class="mb-4">
    <div class="search-box">
        <i class="fas fa-search search-icon"></i>
        <input type="text" name="ara" value="@ViewBag.Ara"
               placeholder="Yazılarda ara..." class="search-input" />
        <button type="submit" class="search-btn">Ara</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-feather-alt d-block"></i>
        <h5 style="color:#6060a0">Henüz yazı yok</h5>
        <p>İlk yazını ekleyerek başla!</p>
        <a href="/Blog/Ekle" class="btn-save mt-3 d-inline-block">İlk Yazımı Ekle</a>
    </div>
}

@foreach (var yazi in Model.OrderByDescending(x => x.Tarih))
{
    <div class="blog-card">
        <div class="d-flex justify-content-between align-items-start">
            <div style="flex:1">
                <h5>@yazi.Baslik</h5>
                <p>@(yazi.Icerik.Length > 120 ? yazi.Icerik.Substring(0, 120) + "..." : yazi.Icerik)</p>
                <span class="badge-date"><i class="fas fa-calendar-alt me-1"></i>@yazi.Tarih.ToString("dd MMMM yyyy")</span>
                @if (yazi.Kategori != null)
                {
                    <span class="badge-date" style="background:rgba(13,110,253,0.15); color:#60a5fa">
                        <i class="fas fa-tag me-1"></i>@yazi.Kategori.Ad
                    </span>
                }
            </div>
            <div class="d-flex gap-2 ms-3">
                <a href="/Blog/Duzenle/@yazi.Id" class="btn-edit"><i class="fas fa-edit me-1"></i>Düzenle</a>
                <a href="/Blog/Sil/@yazi.Id" class="btn-delete"
                       onclick="return confirm('Bu yazıyı silmek istediğine emin misin?')">
                    <i class="fas fa-trash me-1"></i>Sil
                </a>
            </div>
        </div>
    </div>
}

<!-- YORUMLAR -->
<div class="d-flex justify-content-between align-items-center mb-3 mt-5">
    <h5 style="color:white">💬 Son Yorumlar</h5>
    <small style="color:#6060a0">@ViewBag.YorumSayisi yorum</small>
</div>

@if (ViewBag.Yorumlar != null && (ViewBag.Yorumlar as List<KisselBlog.Models.Yorum>).Any())
{
    @foreach (var yorum in ViewBag.Yorumlar as List<KisselBlog.Models.Yorum>)
    {
        <div class="blog-card d-flex justify-content-between align-items-start">
            <div>
                <div style="color:#a78bfa; font-weight:600; margin-bottom:5px">
                    <i class="fas fa-user-circle me-2"></i>@yorum.YazarAdi
                </div>
                <div style="color:#7070a0; font-size:0.9rem; margin-bottom:8px">@yorum.Icerik</div>
                <span class="badge-date">
                    <i class="fas fa-file-alt me-1"></i>
                    @(yorum.BlogYazisi != null ? yorum.BlogYazisi.Baslik : "")
                </span>
                <span class="badge-date ms-2">
                    <i class="fas fa-clock me-1"></i>@yorum.Tarih.ToString("dd MMM yyyy")
                </span>
            </div>
            <a href="/Blog/YorumSil/@yorum.Id" class="btn-delete ms-3"
                   onclick="return confirm('Bu yorumu silmek istediğine emin misin?')">
                <i class="fas fa-trash me-1"></i>Sil
            </a>
        </div>
    }
}
else
{
    <div class="empty-state">
        <i class="fas fa-comment-slash d-block"></i>
        <p style="color:#4040a0">Henüz yorum yok</p>
    </div>
}