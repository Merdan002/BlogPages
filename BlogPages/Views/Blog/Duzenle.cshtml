@model KisselBlog.Models.BlogYazisi

<div class="hero">
    <h1>✏️ Yazıyı Düzenle</h1>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body p-4">
                    <form method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Tarih" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Başlık</label>
                            <input asp-for="Baslik" class="form-control form-control-lg" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">İçerik</label>
                            <textarea asp-for="Icerik" class="form-control" rows="8"></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">💾 Kaydet</button>
                            <a href="/Blog" class="btn btn-secondary">Geri Dön</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>