@model KisselBlog.Models.BlogYazisi

<div class="topbar">
    <div>
        <h4>✏️ Yeni Yazı Ekle</h4>
        <small style="color:#6060a0">Yeni bir blog yazısı oluştur.</small>
    </div>
    <a href="/Blog" class="btn-edit"><i class="fas fa-arrow-left me-2"></i>Geri Dön</a>
</div>

<div class="form-card">
    <form method="post">
        <div class="mb-4">
            <label class="form-label">Başlık</label>
            <input asp-for="Baslik" class="form-control" placeholder="Yazı başlığını gir..." />
        </div>
        <div class="mb-4">
            <label class="form-label">Kategori</label>
            <select asp-for="KategoriId" class="form-select">
                <option value="">-- Kategori Seç --</option>
                @foreach (var k in ViewBag.Kategoriler as List<KisselBlog.Models.Kategori>)
                {
                    <option value="@k.Id">@k.Ad</option>
                }
            </select>
        </div>
        <div class="mb-4">
            <label class="form-label">İçerik</label>
            <textarea asp-for="Icerik" class="form-control" rows="10" placeholder="Yazını buraya yaz..."></textarea>
        </div>
        <div class="d-flex gap-3">
            <button type="submit" class="btn-save"><i class="fas fa-save me-2"></i>Yayınla</button>
            <a href="/Blog" class="btn-delete">İptal</a>
        </div>
    </form>
</div>