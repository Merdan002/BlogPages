 @model List<KisselBlog.Models.BlogYazisi>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>📖 Kişisel Blogum</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #0f0f1a;
            color: #e0e0e0;
            font-family: 'Segoe UI', sans-serif;
        }

        /* NAVBAR */
        .navbar {
            background: #1a1a2e;
            border-bottom: 1px solid #2a2a4a;
            padding: 15px 0;
        }

        .navbar-brand {
            color: #a78bfa !important;
            font-weight: 700;
            font-size: 1.3rem;
        }

        .btn-giris {
            background: linear-gradient(135deg, #6f42c1, #0d6efd);
            color: white !important;
            border: none;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 0.9rem;
            text-decoration: none;
            transition: opacity 0.2s;
        }

        .btn-giris:hover { opacity: 0.85; }

        /* HERO */
        .hero {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            border-bottom: 1px solid #2a2a4a;
            padding: 80px 0;
            text-align: center;
        }

        .hero h1 {
            font-size: 2.8rem;
            font-weight: 800;
            color: white;
            margin-bottom: 15px;
        }

        .hero h1 span {
            background: linear-gradient(135deg, #a78bfa, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero p { color: #6060a0; font-size: 1.1rem; }

        /* YAZALAR */
        .section { padding: 50px 0; }

        .blog-card {
            background: #1a1a2e;
            border: 1px solid #2a2a4a;
            border-radius: 16px;
            padding: 25px;
            margin-bottom: 24px;
            transition: border-color 0.2s, transform 0.2s;
            text-decoration: none;
            display: block;
            color: inherit;
        }

        .blog-card:hover {
            border-color: #6f42c1;
            transform: translateY(-3px);
            color: inherit;
        }

        .blog-card h4 { color: white; font-weight: 700; margin-bottom: 10px; }
        .blog-card p  { color: #7070a0; font-size: 0.95rem; margin-bottom: 15px; }

        .badge-date {
            background: rgba(111,66,193,0.15);
            color: #a78bfa;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
        }

        .badge-oku {
            background: rgba(13,110,253,0.15);
            color: #60a5fa;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
        }

        /* FOOTER */
        .footer {
            background: #1a1a2e;
            border-top: 1px solid #2a2a4a;
            text-align: center;
            padding: 30px;
            color: #4040a0;
            margin-top: 40px;
        }

        /* BOŞ STATE */
        .empty {
            text-align: center;
            padding: 80px 20px;
            color: #4040a0;
        }

        .empty i { font-size: 3rem; margin-bottom: 20px; display: block; }
        /* ARAMA */
.search-box {
    display: flex;
    align-items: center;
    background: #0f0f1a;
    border: 1px solid #2a2a4a;
    border-radius: 12px;
    padding: 6px 6px 6px 16px;
    max-width: 500px;
    margin: 0 auto;
}

.search-icon { color: #6060a0; margin-right: 10px; }

.search-input {
    background: transparent;
    border: none;
    outline: none;
    color: #e0e0e0;
    font-size: 0.95rem;
    flex: 1;
}

    .search-input::placeholder { color: #4040a0; }

    .search-btn {
    background: linear-gradient(135deg, #6f42c1, #0d6efd);
    color: white;
    border: none;
    padding: 8px 18px;
    border-radius: 8px;
    font-size: 0.85rem;
    cursor: pointer;
    transition: opacity 0.2s;
}

    .search-btn:hover { opacity: 0.85; }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="container d-flex justify-content-between align-items-center">
            <a class="navbar-brand" href="/Blog/Anasayfa">
                <i class="fas fa-book-open me-2"></i>Kişisel Blogum
            </a>
            <a href="/Giris" class="btn-giris">
                <i class="fas fa-lock me-2"></i>Yönetim Paneli
            </a>
        </div>
    </nav>

    <!-- HERO -->
     <div class="hero">
    <div class="container">
        <h1>Merhaba, ben <span>Blogcuyum!</span> 👋</h1>
        <p>Düşüncelerimi, notlarımı ve deneyimlerimi burada paylaşıyorum.</p>

        <form method="get" action="/Blog/Anasayfa" class="mt-4">
            <div class="search-box">
                <i class="fas fa-search search-icon"></i>
                <input type="text" name="ara" value="@ViewBag.Ara"
                       placeholder="Yazılarda ara..." class="search-input" />
                <button type="submit" class="search-btn">Ara</button>
            </div>
        </form>
    </div>
</div>

    <!-- YAZILAR -->
    <div class="section">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 style="color:white">📝 Son Yazılar</h3>
                <small style="color:#6060a0">@Model.Count yazı</small>
            </div>

            @if (!Model.Any())
{
    <div class="empty">
        <i class="fas fa-feather-alt"></i>
        @if (ViewBag.Ara != null)
        {
            <h5>"@ViewBag.Ara" için sonuç bulunamadı</h5>
            <p><a href="/Blog/Anasayfa" style="color:#a78bfa">Tüm yazıları gör</a></p>
        }
        else
        {
            <h5>Henüz yazı yok</h5>
            <p>Yakında içerikler eklenecek!</p>
        }
    </div>
}

            @foreach (var yazi in Model)
            {
                <a href="/Blog/Detay/@yazi.Id" class="blog-card">
                    <h4>@yazi.Baslik</h4>
                    <p>@(yazi.Icerik.Length > 150 ? yazi.Icerik.Substring(0, 150) + "..." : yazi.Icerik)</p>
                    <div class="d-flex gap-2">
                        <span class="badge-date"><i class="fas fa-calendar me-1"></i>@yazi.Tarih.ToString("dd MMMM yyyy")</span>
                        <span class="badge-oku"><i class="fas fa-arrow-right me-1"></i>Devamını Oku</span>
                    </div>
                </a>
            }
        </div>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        <p>© 2024 Kişisel Blogum — ASP.NET Core ile yapıldı 💜</p>
    </div>

</body>
</html>