 <!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>📖 Kişisel Blogum</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: #0f0f1a;
            color: #e0e0e0;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            min-height: 100vh;
        }

        /* ---- SIDEBAR ---- */
        .sidebar {
            width: 260px;
            min-height: 100vh;
            background: linear-gradient(180deg, #1a1a2e, #16213e);
            padding: 30px 20px;
            position: fixed;
            top: 0; left: 0;
            border-right: 1px solid #2a2a4a;
            z-index: 100;
        }

        .sidebar-brand {
            font-size: 1.4rem;
            font-weight: 700;
            color: #a78bfa;
            margin-bottom: 40px;
            display: block;
            text-decoration: none;
        }

        .sidebar-brand span { color: white; }

        .nav-section {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #555580;
            margin: 20px 0 10px;
        }

        .sidebar .nav-link {
            color: #9090b0 !important;
            padding: 10px 15px;
            border-radius: 10px;
            margin-bottom: 5px;
            transition: all 0.2s;
            font-size: 0.95rem;
        }

        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            background: linear-gradient(135deg, #6f42c1, #0d6efd);
            color: white !important;
        }

        .sidebar .nav-link i { width: 20px; margin-right: 10px; }

        /* ---- MAIN CONTENT ---- */
        .main-content {
            margin-left: 260px;
            flex: 1;
            padding: 30px;
        }

        /* ---- TOPBAR ---- */
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .topbar h4 {
            color: white;
            font-weight: 700;
        }

        .topbar .btn-new {
            background: linear-gradient(135deg, #6f42c1, #0d6efd);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            transition: opacity 0.2s;
        }

        .topbar .btn-new:hover { opacity: 0.85; color: white; }

        /* ---- STAT CARDS ---- */
        .stat-card {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            border: 1px solid #2a2a4a;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
        }

        .stat-card .icon {
            width: 50px; height: 50px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem;
            margin-bottom: 15px;
        }

        .icon-purple { background: rgba(111,66,193,0.2); color: #a78bfa; }
        .icon-blue   { background: rgba(13,110,253,0.2); color: #60a5fa; }
        .icon-green  { background: rgba(25,135,84,0.2);  color: #4ade80; }

        .stat-card h3 { color: white; font-size: 2rem; font-weight: 700; }
        .stat-card p  { color: #6060a0; font-size: 0.85rem; margin: 0; }

        /* ---- BLOG CARDS ---- */
        .blog-card {
            background: #1a1a2e;
            border: 1px solid #2a2a4a;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 16px;
            transition: border-color 0.2s, transform 0.2s;
        }

        .blog-card:hover {
            border-color: #6f42c1;
            transform: translateY(-2px);
        }

        .blog-card h5 { color: white; font-weight: 600; margin-bottom: 8px; }
        .blog-card p  { color: #7070a0; font-size: 0.9rem; margin-bottom: 12px; }

        .badge-date {
            background: rgba(111,66,193,0.15);
            color: #a78bfa;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.78rem;
        }

        .btn-edit {
            background: rgba(13,110,253,0.15);
            color: #60a5fa;
            border: none;
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 0.85rem;
            text-decoration: none;
            transition: background 0.2s;
        }

        .btn-edit:hover { background: rgba(13,110,253,0.3); color: #60a5fa; }

        .btn-delete {
            background: rgba(220,53,69,0.15);
            color: #f87171;
            border: none;
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 0.85rem;
            text-decoration: none;
            transition: background 0.2s;
        }

        .btn-delete:hover { background: rgba(220,53,69,0.3); color: #f87171; }

        /* ---- FORM ---- */
        .form-card {
            background: #1a1a2e;
            border: 1px solid #2a2a4a;
            border-radius: 16px;
            padding: 30px;
        }

        .form-control, .form-select {
            background: #0f0f1a !important;
            border: 1px solid #2a2a4a !important;
            color: #e0e0e0 !important;
            border-radius: 10px;
        }

        .form-control:focus, .form-select:focus {
            border-color: #6f42c1 !important;
            box-shadow: 0 0 0 3px rgba(111,66,193,0.2) !important;
        }

        .form-label { color: #9090b0; font-size: 0.9rem; margin-bottom: 6px; }

        .btn-save {
            background: linear-gradient(135deg, #6f42c1, #0d6efd);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 10px;
            font-weight: 600;
            transition: opacity 0.2s;
        }

        .btn-save:hover { opacity: 0.85; color: white; }

        /* ---- EMPTY STATE ---- */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #4040a0;
        }

        .empty-state i { font-size: 3rem; margin-bottom: 15px; }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <a class="sidebar-brand" href="/"><i class="fas fa-book-open me-2"></i><span>Kişisel</span> Blog</a>

        <div class="nav-section">Menü</div>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" href="/Blog">
            <i class="fas fa-home"></i> Dashboard
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Ekle" ? "active" : "")" href="/Blog/Ekle">
            <i class="fas fa-plus-circle"></i> Yeni Yazı
        </a>

        <div class="nav-section mt-4">Sistem</div>
        <a class="nav-link" href="#">
            <i class="fas fa-cog"></i> Ayarlar
        </a>
        <div class="nav-section mt-4">Hesap</div>
         <a class="nav-link" href="/Giris/Cikis">
         <i class="fas fa-sign-out-alt"></i> Çıkış Yap
         </a>
    </div>

    <!-- MAIN -->
    <div class="main-content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>